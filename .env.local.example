# Cashfree Payment Gateway Configuration
# Get these from: https://merchant.cashfree.com/merchants/login

# Test Mode (for development)
NEXT_PUBLIC_CASHFREE_APP_ID=your_test_app_id_here
CASHFREE_SECRET_KEY=your_test_secret_key_here
NEXT_PUBLIC_CASHFREE_ENV=TEST

# Production Mode (uncomment when going live)
# NEXT_PUBLIC_CASHFREE_APP_ID=your_production_app_id_here
# CASHFREE_SECRET_KEY=your_production_secret_key_here
# NEXT_PUBLIC_CASHFREE_ENV=PROD

# Your website URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
