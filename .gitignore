# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — ignore every .env variant (secrets live only in encrypted
# GitHub Actions secrets, never on disk), but keep the committed template.
.env*
!.env.example

# agent artifacts (research notes, generated scratch — never committed)
.agents/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
/.cursor/*
*.md
!DEPLOYMENT.md
!README.md
!QUICK-START.md
!.env.example
!docs/archive/*.md
!docs/social/*.md
!docs/superpowers/specs/*.md
!docs/superpowers/plans/*.md
!scripts/pinterest/SETUP.md

