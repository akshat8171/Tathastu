# =============================================================================
# Layerix — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.
# =============================================================================

# Supabase
# Get these from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key

# Service-role key — SERVER-SIDE ONLY. Used by lib/supabase/admin.ts for
# order writes/reads/updates that must bypass RLS (mark-paid, confirmation
# read). migration-002 grants the browser anon role INSERT only, so without
# this key orders stay "pending" and the confirmation page 404s.
# !! NEVER prefix this with NEXT_PUBLIC_ — that would leak it to the browser. !!
# Get it from: Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Razorpay
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── E2E TESTING (local only) ─────────────────────────────────────────────────
# Mock payment: when 'true' AND not a production build, the checkout skips the
# real Razorpay modal and writes a real order straight to Supabase. This lets
# you test the full create→pay→confirmation flow without Razorpay keys.
# It is HARD-DISABLED in every Vercel build (NODE_ENV=production), so it can
# never charge-bypass in production. Leave blank/unset for real payments.
# OTP is mocked separately via Supabase "Test OTP" (dashboard) — see
# docs/E2E_TESTING_GUIDE.md. No env var needed for that.
NEXT_PUBLIC_MOCK_PAYMENT=

# Upstash Redis — OTP rate limiting (OPTIONAL but recommended for production)
# Without these, OTP rate limiting falls back to per-instance in-memory
# (works locally; not effective across serverless instances).
# Get these from: https://console.upstash.com → create a Redis database → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
